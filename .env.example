# =============================================================================
# Resume Matcher — Environment Variables Reference
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# =============================================================================

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=dev
# Options: dev | prod
# dev  → DEBUG logging, console format (color), relaxed rate limits
# prod → INFO logging, JSON format, strict rate limits

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://matcher:matcherpass@localhost:5432/resume_matcher
POSTGRES_DB=resume_matcher
POSTGRES_USER=matcher
POSTGRES_PASSWORD=matcherpass

# ── Redis (Broker + Cache) ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Supports any OpenAI-compatible endpoint (OpenRouter, Together, Groq, direct OpenAI).
# To swap provider: change these three values only. No code changes needed.
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=qwen/qwen3-6b-plus:free
LLM_API_KEY=sk-or-...

# LLM rate limit (requests per minute). Match your provider's plan limit.
LLM_MAX_RPM=20

# Enable verbose CrewAI agent logs. Recommended true only for debugging.
LLM_VERBOSE=false

# ── Docling (Document Extraction) ─────────────────────────────────────────────
DOCLING_USE_GPU=false
DOCLING_DEVICE_ID=0
DOCLING_TABLE_AWARE=true
DOCLING_OCR_ENABLED=true

# ── Langfuse (Tracing — Optional) ─────────────────────────────────────────────
# Leave empty to disable tracing. App will continue without it.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3000

# Langfuse DB (only needed when running langfuse via docker-compose --profile langfuse)
LANGFUSE_DB_NAME=langfuse
LANGFUSE_DB_USER=langfuse
LANGFUSE_DB_PASSWORD=langfusepass
LANGFUSE_NEXTAUTH_SECRET=changeme-in-production

# ── Storage ────────────────────────────────────────────────────────────────────
# v1: local filesystem. v2: s3/r2 (swap by changing STORAGE_TYPE only)
STORAGE_TYPE=local
STORAGE_BASE_PATH=./storage

# S3/R2 (only required when STORAGE_TYPE=s3)
S3_ENDPOINT_URL=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET_NAME=resume-matcher

# ── Token Budgets (per crew profile) ──────────────────────────────────────────
TOKEN_BUDGET_QUICK=8000
TOKEN_BUDGET_STANDARD=15000
TOKEN_BUDGET_FULL=22000

# ── Limits ────────────────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=10
MAX_BATCH_SIZE=200
RATE_LIMIT_PER_MINUTE=30

# Crew + Docling execution timeouts (seconds)
CREW_EXECUTION_TIMEOUT=300
DOCLING_EXTRACTION_TIMEOUT=60

# ── DB Pool ───────────────────────────────────────────────────────────────────
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
